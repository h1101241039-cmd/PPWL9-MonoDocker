{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    
    // Solusi modern pengganti baseUrl
    "paths": {
      "@/*": ["./src/*"],
      "prisma/*": ["./prisma/*"]
    },
    "ignoreDeprecations": "5.0"
  },
  "include": [
    "src/**/*.ts",
    "prisma/**/*.ts" 
  ],
  "exclude": ["node_modules"]
}